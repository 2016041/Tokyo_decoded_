# Tokyo Decoded LP — 環境変数テンプレート
#
# 使用方法:
#   1. このファイルを .env.local にコピー（cp .env.local.example .env.local）
#   2. 各値を実値に差し替え
#   3. Vercel ダッシュボードで本番環境にも同名で登録
#
# 注意:
#   - .env.local は .gitignore 済み（コミット禁止）
#   - NEXT_PUBLIC_* はクライアントバンドルに含まれる（秘匿不可、公開キーのみ）
#   - それ以外はサーバサイド専用（API Route Handler から参照）

# ===== サイト共通 =====

# 本番ドメイン（preview 環境では Vercel が自動で別値を注入）
NEXT_PUBLIC_SITE_URL=https://tokyo-decoded.com

# ===== Resend（メール配信・問い合わせ転送）=====

# Resend ダッシュボードで発行: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 配信元アドレス（Resend で検証済みドメインの送信元）
RESEND_FROM=noreply@tokyo-decoded.com

# 問い合わせ転送先（X-3 の /api/contact が転送する宛先）
CONTACT_TO=hello@tokyo-decoded.com

# ===== Google reCAPTCHA v3（問い合わせフォームスパム対策）=====

# Google reCAPTCHA admin: https://www.google.com/recaptcha/admin
# v3 のサイトキー（クライアントで grecaptcha.execute() に使用）
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# v3 のシークレットキー（サーバで検証に使用、スコア 0.5+ のみ通過）
RECAPTCHA_SECRET_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Google Sheets（メールリスト管理）=====

# サービスアカウント作成: https://console.cloud.google.com/iam-admin/serviceaccounts
# Google Sheets API を有効化し、対象シートに編集権限を付与
GOOGLE_SHEETS_CLIENT_EMAIL=tokyo-decoded@xxxxxxxx.iam.gserviceaccount.com

# サービスアカウント JSON の private_key（改行は \n でエスケープ）
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# 対象スプレッドシート ID（URL の /d/{ID}/edit 部分）
GOOGLE_SHEETS_SPREADSHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Google Analytics 4 =====

# 測定 ID（G-XXXXXXXXXX 形式）
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
